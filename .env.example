# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/?appName=Cluster0

# ─── AI ───────────────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com)
GEMINI_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
# Gmail address for sending notifications
EMAIL_USER=you@gmail.com
# Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Cloudinary (Media Uploads) ───────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── App URL ──────────────────────────────────────────────────────────────────
# Set this to your Render service URL AFTER first deploy
# Used by Socket.IO client to connect to the correct server
NEXT_PUBLIC_APP_URL=https://your-app-name.onrender.com
